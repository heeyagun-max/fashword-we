---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// SITE_TITLE과 SITE_DESCRIPTION은 consts.ts에서 불러오지만, 랜딩용으로 직접 덮어씌울 수 있습니다.
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="FASHword | Personalized Fit Engine" description="AI-powered personalized sewing pattern & fit-adjustment platform." />
		<style>
			/* The Row Inspired Minimalist Aesthetic */
			body {
				background-color: #F7F7F5; /* 톤다운된 웜 오프화이트 (The Row 특유의 배경톤) */
				color: #2C2C2C; /* 퓨어 블랙 대신 부드러운 차콜 그레이 */
				font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
				-webkit-font-smoothing: antialiased;
				margin: 0;
				padding: 0;
			}
			main {
				max-width: 720px; /* 텍스트가 너무 넓게 퍼지지 않도록 좁은 폭 유지 */
				margin: 0 auto;
				padding: 140px 24px;
				text-align: center;
			}
			.hero {
				margin-bottom: 80px;
			}
			.subtitle {
				font-size: 0.85rem;
				color: #737373;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				margin-bottom: 24px;
			}
			h1 {
				font-family: 'Times New Roman', Times, serif; /* 고급스러운 에디토리얼 세리프 */
				font-weight: 400;
				font-size: 3.2rem;
				letter-spacing: -0.02em;
				margin-bottom: 32px;
				line-height: 1.1;
			}
			.description {
				font-size: 1.15rem;
				line-height: 1.8;
				color: #555555;
				margin: 0 auto;
				max-width: 540px;
			}
			.divider {
				width: 30px;
				height: 1px;
				background-color: #D1D1D1;
				margin: 80px auto;
			}
			.section-title {
				font-family: 'Times New Roman', Times, serif;
				font-weight: 400;
				font-size: 1.6rem;
				margin-bottom: 24px;
				color: #2C2C2C;
			}
			p {
				font-size: 0.95rem;
				line-height: 1.9;
				color: #666666;
				margin: 0 auto 40px auto;
				max-width: 580px;
				text-align: center;
			}
			.contact-btn {
				display: inline-block;
				padding: 16px 40px;
				background-color: transparent;
				color: #2C2C2C;
				text-decoration: none;
				font-size: 0.8rem;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				border: 1px solid #2C2C2C;
				transition: all 0.4s ease;
				margin-top: 20px;
			}
			.contact-btn:hover {
				background-color: #2C2C2C;
				color: #F7F7F5;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<div class="subtitle">AI Fit Engine for Home Sewists</div>
				<h1>FASHword</h1>
				<div class="description">
					Bridging the gap between static drafting templates and diverse body morphologies.
				</div>
			</div>

			<div class="divider"></div>

			<h2 class="section-title">The Problem</h2>
			<p>
				Millions of creators struggle because standardized commercial patterns rarely fit real bodies. 
				Even with meticulous construction, systemic mismatches in proportions lead to abandoned projects and fabric waste.
			</p>

			<h2 class="section-title">The Solution</h2>
			<p>
				FASHword leverages AI to translate human body measurements, fit preferences, and qualitative feedback 
				into customized PDF patterns and precise adjustment guidance.
			</p>

			<a href="mailto:hello@fashword.kr" class="contact-btn">Join the Waitlist</a>
		</main>
		<Footer />
	</body>
</html>
